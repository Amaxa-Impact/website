---
interface Props {
  name: string;
  role: string;
  linkedinHref?: string;
}
const { name, role, linkedinHref } = Astro.props;
---

<div class="bg-white rounded-[36px] px-8 py-6 flex flex-col gap-2">
  <div class="flex items-start justify-between">
    <div class="flex flex-col gap-1">
      <p class="text-[26px] font-bold text-purple-dark-500 leading-[1.6]">{name}</p>
      <p class="text-base text-muted-foreground leading-[1.6]">{role}</p>
    </div>
    {linkedinHref && (
      <a href={linkedinHref} target="_blank" rel="noopener noreferrer" class="shrink-0 mt-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 28 28" fill="none">
          <rect width="28" height="28" rx="6" fill="#2e1f54" fill-opacity="0.08"/>
          <path d="M8 10.5h2.5V20H8V10.5Zm1.25-4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12.5 10.5H15v1.3c.4-.7 1.4-1.5 2.8-1.5C20 10.3 20 12.2 20 14v6h-2.5v-5c0-1.2 0-2.7-1.5-2.7s-1.5 1.3-1.5 2.6V20h-2.5V10.5Z" fill="#2e1f54"/>
        </svg>
      </a>
    )}
  </div>
</div>

---
interface Props {
  url?: string;
  title?: string;
}

const { url = "", title = "" } = Astro.props;

const socials = [
  { label: "Facebook", icon: "f", href: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}` },
  { label: "X / Twitter", icon: "X", href: `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}` },
  { label: "LinkedIn", icon: "in", href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}` },
  { label: "Pinterest", icon: "P", href: `https://pinterest.com/pin/create/button/?url=${encodeURIComponent(url)}` },
  { label: "Email", icon: "@", href: `mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(url)}` },
  { label: "Copy link", icon: "↗", href: url },
];
---

<div class="bg-neutral-1-500 w-full px-6 sm:px-12 lg:px-[200px] pt-2 pb-18 flex flex-col gap-7">
  <div class="bg-border h-px w-full" />
  <div class="flex gap-4 items-center">
    <span class="font-semibold text-xl md:text-[32px] text-purple-dark-500 leading-[1.22]">Share</span>
    {socials.map((s) => (
      <a
        href={s.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={s.label}
        class="size-10 rounded-[20px] border-[1.5px] border-purple-dark-500 flex items-center justify-center text-base text-purple-dark-500 hover:bg-purple-dark-500 hover:text-white transition-colors"
      >
        {s.icon}
      </a>
    ))}
  </div>
</div>

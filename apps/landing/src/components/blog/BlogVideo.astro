---
interface Props {
  vimeoId: string;
  vimeoHash: string;
  title?: string;
}

const { vimeoId, vimeoHash, title = "" } = Astro.props;
const src = `https://player.vimeo.com/video/${vimeoId}?h=${vimeoHash}&badge=0&autopause=0&player_id=0&app_id=58479`;
---

<div class="w-full max-w-[1040px]">
  <div class="relative w-full" style="padding-bottom: 56.25%;">
    <iframe
      src={src}
      frameborder="0"
      allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
      referrerpolicy="strict-origin-when-cross-origin"
      style="position:absolute;top:0;left:0;width:100%;height:100%;"
      title={title}
    ></iframe>
  </div>
</div>

<script src="https://player.vimeo.com/api/player.js" is:inline></script>

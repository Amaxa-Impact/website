---
interface Stat {
  number: string;
  label: string;
}

interface Props {
  title?: string;
  stats?: Stat[];
  ctaLabel?: string;
  ctaHref?: string;
}

const defaultStats: Stat[] = [
  { number: "719M", label: "lives impacted since 2001" },
  { number: "241", label: "portfolio companies improving lives" },
  { number: "$312M", label: "deployed to scale solutions" },
  { number: "1796", label: "Academy alumni driving real-world impact" },
];

const {
  title = "Success equals impact",
  stats = defaultStats,
  ctaLabel = "Learn more",
  ctaHref = "/about-us",
} = Astro.props;
---

<section class="bg-neutral-1-500 w-full px-12 py-24 flex flex-col gap-12">
  <h2 class="font-semibold text-[40px] text-foreground">{title}</h2>
  <div class="flex flex-wrap gap-14">
    {stats.map((s) => (
      <div class="flex flex-col gap-2.5 w-[280px]">
        <p class="font-bold text-[88px] text-foreground leading-none">{s.number}</p>
        <p class="font-normal text-lg text-foreground">{s.label}</p>
      </div>
    ))}
  </div>
  <a
    href={ctaHref}
    class="inline-flex items-center gap-2 border-[1.5px] border-purple-dark-500 rounded-full px-6 py-3 text-base font-semibold text-purple-dark-500 hover:bg-purple-dark-500 hover:text-white transition-colors w-fit"
  >
    {ctaLabel}
  </a>
</section>

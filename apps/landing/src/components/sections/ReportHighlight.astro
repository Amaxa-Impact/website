---
interface Props {
  eyebrow?: string;
  title: string;
  body: string;
  ctaLabel?: string;
  ctaHref?: string;
  imageSrc?: string;
  imageAlt?: string;
}
const {
  eyebrow = "Annual Report",
  title,
  body,
  ctaLabel = "View report now",
  ctaHref = "#",
  imageSrc,
  imageAlt = "",
} = Astro.props;
---

<section class="bg-neutral-1-500 w-full py-12 px-6 md:px-12">
  <div class="flex flex-col gap-8 items-center lg:flex-row lg:gap-[72px]">
    <!-- Left: large image -->
    <div class="shrink-0 w-full max-w-[814px] aspect-[814/530] rounded-[32px] bg-neutral-2-500 border-2 border-white overflow-hidden md:border-[5px] lg:w-[814px] lg:h-[530px] lg:aspect-auto">
      {imageSrc && (
        <img src={imageSrc} alt={imageAlt} class="w-full h-full object-cover" />
      )}
    </div>

    <!-- Right: text -->
    <div class="flex flex-col gap-5 max-w-[420px]">
      <div class="flex items-center gap-2 text-purple-dark-500">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path d="M3 2h8l4 4v10H3V2Zm8 0v4h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <p class="text-base font-semibold">{eyebrow}</p>
      </div>

      <h2 class="text-2xl md:text-[36px] font-semibold text-purple-dark-500 leading-[1.1]">{title}</h2>
      <p class="text-base text-purple-dark-400 leading-[1.5]">{body}</p>

      <a
        href={ctaHref}
        class="text-base font-semibold text-purple-dark-500 hover:text-coral-dark-500 transition-colors"
      >
        {ctaLabel} →
      </a>
    </div>
  </div>
</section>

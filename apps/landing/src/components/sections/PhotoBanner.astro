---
interface Props {
  heading: string;
  body?: string;
  eyebrow?: string;
  imageSrc?: string;
  imageAlt?: string;
  showButton?: boolean;
  showText?: boolean;
  buttonLabel?: string;
  buttonHref?: string;
}
const {
  heading,
  body,
  eyebrow = "FEATURED PROJECT",
  imageSrc,
  imageAlt = "",
  showButton = true,
  showText = true,
  buttonLabel = "▶ Watch",
  buttonHref = "#",
} = Astro.props;
---

<section class="bg-purple-dark-500 relative w-full h-[720px] overflow-hidden">
  {imageSrc && (
    <img
      src={imageSrc}
      alt={imageAlt}
      class="absolute inset-0 w-full h-full object-cover"
    />
  )}

  <!-- Purple gradient scrim (directional — text sits on the dark left on desktop) -->
  <div class="absolute inset-0 bg-gradient-to-r from-purple-dark-500/75 via-purple-dark-500/15 to-transparent"></div>
  <!-- Extra uniform darkening on mobile, where the text spans the full width -->
  <div class="absolute inset-0 bg-purple-dark-500/55 md:hidden"></div>

  <!-- Content: even px-6 insets on mobile (matches the sections above/below), left-16 on desktop -->
  <div class="absolute left-6 right-6 top-1/2 -translate-y-1/2 flex flex-col gap-5 max-w-[640px] md:left-16 md:right-auto md:gap-6">
    <p class="text-lg md:text-2xl font-semibold uppercase tracking-[0.1em] text-white/90">{eyebrow}</p>
    <h2 class="text-2xl md:text-3xl lg:text-[44px] font-bold text-white leading-[1.15]">{heading}</h2>
    {showText && body && (
      <p class="text-lg md:text-2xl text-white/85 leading-[1.4]">{body}</p>
    )}
    {showButton && (
      <a
        href={buttonHref}
        class="mt-2 inline-flex items-center gap-2 bg-white text-purple-dark-500 text-base font-semibold px-6 py-3 rounded-full hover:bg-neutral-1-500 transition-colors w-fit"
      >
        {buttonLabel}
      </a>
    )}
  </div>
</section>

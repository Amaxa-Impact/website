---
interface Props {
  heading: string;
  body?: string;
  learnMoreHref?: string;
  learnMoreLabel?: string;
  imageSrc?: string;
  imageAlt?: string;
}
const { heading, body, learnMoreHref, learnMoreLabel = "Learn more", imageSrc, imageAlt = "" } = Astro.props;
---

<section class="relative w-full h-[600px] overflow-hidden bg-purple-dark-500">
  {imageSrc && (
    <img
      src={imageSrc}
      alt={imageAlt}
      class="absolute inset-0 w-full h-full object-cover"
    />
  )}

  <!-- Left gradient scrim -->
  <div class="absolute inset-0 bg-gradient-to-r from-black/[0.62] via-black/[0.18] to-transparent"></div>

  <!-- Content -->
  <div class="absolute left-24 top-[108px] flex flex-col gap-6 max-w-[660px]">
    <h2 class="text-2xl md:text-[36px] font-bold text-white leading-[1.2]">{heading}</h2>
    {body && (
      <p class="text-2xl text-white/90 leading-[1.4]">{body}</p>
    )}
    {learnMoreHref && (
      <a
        href={learnMoreHref}
        class="mt-2 inline-flex items-center gap-2 border border-white text-white text-base font-semibold px-6 py-3 rounded-full hover:bg-white hover:text-purple-dark-500 transition-colors w-fit"
      >
        {learnMoreLabel} →
      </a>
    )}
  </div>
</section>

---
interface Logo {
  src?: string;
  alt: string;
}

interface Props {
  caption?: string;
  logos?: Logo[];
}

const defaultLogos: Logo[] = [
  { alt: "Partner 1" },
  { alt: "Partner 2" },
  { alt: "Partner 3" },
  { alt: "Partner 4" },
  { alt: "Partner 5" },
  { alt: "Partner 6" },
];

const {
  caption = "Partner nonprofits in Palestine, Uganda, Liberia & beyond",
  logos = defaultLogos,
} = Astro.props;
---

<section class="bg-neutral-1-500 w-full px-6 md:px-12 py-18 flex flex-col gap-9 items-center">
  <p class="font-medium text-base text-muted-foreground text-center w-full">{caption}</p>
  <div class="flex items-center justify-between w-full gap-4">
    {logos.map((logo) => (
      <div class="flex-1 h-18 bg-accent rounded-2xl flex items-center justify-center min-w-0">
        {logo.src ? (
          <img src={logo.src} alt={logo.alt} class="max-h-10 max-w-[80%] object-contain" />
        ) : (
          <span class="font-medium text-base text-muted-foreground">{logo.alt}</span>
        )}
      </div>
    ))}
  </div>
</section>

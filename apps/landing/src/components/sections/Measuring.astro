---
interface MeasuringCard {
  title: string;
  body: string;
}

interface Props {
  heading: string;
  subhead?: string;
  cards: MeasuringCard[];
}
const { heading, subhead, cards } = Astro.props;
---

<section class="bg-neutral-1-500 w-full px-6 md:px-12 py-20 flex flex-col gap-14">
  <!-- Top border -->
  <div class="h-px w-full bg-border"></div>

  <!-- Header row -->
  <div class="flex flex-col items-start gap-4 md:flex-row md:justify-between md:gap-20">
    <h2 class="text-2xl md:text-3xl lg:text-[40px] font-semibold text-purple-dark-500 md:whitespace-nowrap md:shrink-0">{heading}</h2>
    {subhead && (
      <p class="text-[18px] text-purple-dark-400 leading-[1.5] max-w-[620px]">{subhead}</p>
    )}
  </div>

  <!-- Cards row -->
  <div class="flex gap-12 items-start">
    {cards.map((card) => (
      <div class="relative flex-1 min-w-0 rounded-[56px] bg-neutral-2-500 border-[5px] border-white px-11 py-[25px] flex flex-col gap-5">
        <p class="text-xl md:text-[32px] font-semibold text-white leading-normal">{card.title}</p>
        <p class="text-[18px] text-white/90 leading-normal">{card.body}</p>
      </div>
    ))}
  </div>
</section>

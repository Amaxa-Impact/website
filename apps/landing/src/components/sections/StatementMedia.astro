---
interface Props {
  statement: string;
  body?: string;
  imageSrc?: string;
  imageAlt?: string;
  learnMoreHref?: string;
  ctaLabel?: string;
}
const { statement, body, imageSrc, imageAlt = "", learnMoreHref, ctaLabel = "Learn more →" } = Astro.props;
---

<section class="bg-white w-full py-20 px-12 flex items-center gap-20">
  <!-- Left: image placeholder -->
  <div class="shrink-0 w-[800px] h-[600px] rounded-[56px] bg-neutral-2-500 border-[5px] border-white overflow-hidden">
    {imageSrc && (
      <img src={imageSrc} alt={imageAlt} class="w-full h-full object-cover" />
    )}
  </div>

  <!-- Right: text -->
  <div class="flex flex-col gap-6 max-w-[440px]">
    <p class="text-[30px] font-normal text-purple-dark-500 leading-[1.4]">{statement}</p>
    {body && (
      <p class="text-base text-purple-dark-400 leading-[1.6]">{body}</p>
    )}
    {learnMoreHref && (
      <a
        href={learnMoreHref}
        class="inline-flex items-center gap-2 text-base font-semibold text-purple-dark-500 hover:text-coral-dark-500 transition-colors"
      >
        {ctaLabel}
      </a>
    )}
  </div>
</section>

---
interface Article {
  category?: string;
  region?: string;
  title: string;
  excerpt?: string;
  href: string;
  imageSrc?: string;
  size?: "large" | "small";
}

interface Props {
  heading?: string;
  subhead?: string;
  articles?: Article[];
}

const {
  heading = "Want to dig deeper?",
  subhead = "Read the latest insights and news on our blog.",
  articles = [],
} = Astro.props;

const [lead, ...rest] = articles;
---

<section class="bg-neutral-1-500 w-full px-6 md:px-20 py-18 flex flex-col gap-9">
  <!-- Header -->
  <div class="flex gap-20 items-start">
    <h2 class="font-bold text-2xl md:text-3xl lg:text-4xl text-foreground leading-[1.08] w-[600px]">{heading}</h2>
    <p class="font-normal text-2xl md:text-3xl lg:text-4xl text-foreground leading-[1.12] w-[600px]">{subhead}</p>
  </div>
  <div class="bg-foreground h-px w-full" />

  <!-- Grid -->
  {articles.length > 0 ? (
    <div class="flex gap-20">
      <!-- Lead article -->
      {lead && (
        <div class="flex flex-col gap-5 w-[600px]">
          <div class="bg-neutral-2-500 rounded-[56px] h-[360px] w-full overflow-hidden">
            {lead.imageSrc && <img src={lead.imageSrc} alt={lead.title} class="w-full h-full object-cover" />}
          </div>
          <div class="flex gap-5 items-center">
            {lead.category && <span class="text-base text-foreground">{lead.category}</span>}
            {lead.region && <span class="flex items-center gap-2 text-base text-foreground">🌐 {lead.region}</span>}
          </div>
          <h3 class="font-normal text-3xl text-foreground leading-[1.2]">{lead.title}</h3>
          {lead.excerpt && <p class="font-normal text-base text-foreground leading-relaxed">{lead.excerpt}</p>}
          <a href={lead.href} class="font-semibold text-base text-foreground hover:text-coral-dark-500 transition-colors">Read more →</a>
        </div>
      )}

      <!-- Side articles -->
      <div class="flex flex-col gap-7 flex-1">
        {rest.map((article, i) => (
          <div>
            {i > 0 && <div class="bg-foreground h-px w-full mb-7" />}
            <div class="flex gap-12 items-center">
              <div class="flex flex-col gap-4 flex-1">
                {article.category && <span class="text-base text-foreground">{article.category}</span>}
                <h3 class="font-normal text-2xl text-foreground leading-[1.24]">{article.title}</h3>
                <a href={article.href} class="font-semibold text-base text-foreground hover:text-coral-dark-500 transition-colors">Read more →</a>
              </div>
              <div class="bg-neutral-2-500 rounded-[56px] size-[150px] shrink-0 overflow-hidden">
                {article.imageSrc && <img src={article.imageSrc} alt={article.title} class="w-full h-full object-cover" />}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  ) : (
    <p class="text-muted-foreground">No articles yet.</p>
  )}
</section>

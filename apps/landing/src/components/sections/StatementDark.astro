---
interface Props {
  statement?: string;
  body?: string;
}

const {
  statement = "Improving the capabilities of and opportunities for people and small enterprises to participate and thrive in market systems, earning a secure living in a digital world.",
  body = "Digital transformation is shaping a new \"future of work\" for individuals and small enterprises alike. It is a critical moment to strengthen market systems and harness digital tools to ensure that everyone — from wage earners and smallholder farmers to gig workers and micro-entrepreneurs — can participate and thrive.",
} = Astro.props;
---

<section class="bg-purple-dark-500 w-full px-6 md:px-12 py-14 flex flex-col gap-7">
  <div class="bg-white/25 h-px w-full" />
  <div class="h-16" />
  <p class="font-normal text-2xl md:text-3xl lg:text-4xl text-white leading-[1.3] max-w-[1300px]">
    {statement}
  </p>
  <p class="font-normal text-base text-white/80 leading-[1.6] max-w-[1040px]">
    {body}
  </p>
</section>

---
interface Props {
  heading: string;
  subhead?: string;
  imageSrc?: string;
  imageAlt?: string;
}
const { heading, subhead, imageSrc, imageAlt = "" } = Astro.props;
---

<section class="bg-neutral-1-500 w-full overflow-hidden border-b border-border">
  <div class="flex flex-col gap-8 px-6 py-12 md:flex-row md:items-center md:justify-between md:gap-12 md:px-20 md:py-0 md:min-h-[560px]">
    <!-- Text content -->
    <div class="flex flex-col gap-4 md:gap-5 md:max-w-[480px]">
      <h2 class="text-[40px] md:text-[60px] font-semibold leading-[1.08] text-purple-dark-500">{heading}</h2>
      {subhead && (
        <p class="text-lg md:text-2xl text-purple-dark-400 leading-[1.4]">{subhead}</p>
      )}
    </div>

    <!-- Profile image -->
    <div class="w-full max-w-[410px] aspect-square md:w-[410px] md:h-[410px] md:shrink-0 rounded-[36px] overflow-hidden bg-coral-light-500">
      {imageSrc && (
        <img src={imageSrc} alt={imageAlt} class="w-full h-full object-cover" />
      )}
    </div>
  </div>
</section>

---
import AppLayout from "@/layouts/app-layout.astro";
import IntroMedia from "@/components/sections/IntroMedia.astro";
import ImpactStats from "@/components/sections/ImpactStats.astro";
import Quote from "@/components/sections/Quote.astro";
import HowItWorks from "@/components/sections/HowItWorks.astro";
import { ProjectFeatureSlider } from "@/components/sections/ProjectFeatureSlider";
import { Faq } from "@/components/sections/Faq";
import { NewsletterCta } from "@/components/sections/NewsletterCta";
import ContactForm from "@/components/sections/ContactForm.astro";
---

<AppLayout
  seo={{
    title: "Ámaxa Cohorts — Apply Today",
    description: "Join Ámaxa Cohorts — a free, fully remote 3-month program pairing high schoolers with global peers and a trained coach to deliver a real project.",
    image: "https://b47pkz22xs.ufs.sh/f/OxFTTzjZGToOLTq5DHnAaWi0jLFr2BdSClosPxeIvEGUbwKy",
    type: "website",
    canonicalURL: "https://www.amaxaimpact.org/programs/cohorts",
    keywords: ["amaxa", "cohorts", "high school", "remote program"],
    noIndex: false,
  }}
>
  <main>

    <IntroMedia
      heading="Cohorts — for high school students"
      subhead="Free and fully remote, pairing high schoolers with global peers and a trained coach to deliver a real project with one of our nonprofit partners."
      imageSrc="/images/programs/cohorts.png"
      imageAlt="Ámaxa Cohorts"
    />

    <ImpactStats
      title="Cohorts by the numbers"
      stats={[
        { number: "100%", label: "Remote — join from anywhere" },
        { number: "52", label: "Countries Students Applied From" },
        { number: "120", label: "Students Completed the Program" },
        { number: "8", label: "Partner nonprofits & initiatives" },
      ]}
      ctaLabel="Apply Today"
      ctaHref="https://airtable.com/appPR9mkslbn3U8YZ/shrHHUtRzK4DqKt3F"
    />

    <Quote
      quote="It's not every day I come across a program that treats students like global leaders."
      attribution="Maitha, 16, from the UAE"
    />

    <HowItWorks
      title="How Cohorts Work"
      steps={[
        { number: "STEP 01", heading: "Apply to the next cohort", description: "Click on the application link to view the next cohort deadline." },
        { number: "STEP 02", heading: "Attend an interview", description: "Tell us about your interests, availability, and which projects excite you most." },
        { number: "STEP 03", heading: "Get matched to a team & project", description: "We match you to a project you're passionate about with a team that meets at times that work for you." },
        { number: "STEP 04", heading: "Meet weekly for 3 months", description: "One-hour weekly meetings with your coach guiding you through planning, problem solving, and execution." },
      ]}
    />

    <ProjectFeatureSlider
      client:load
      heading="Past Cohort Projects"
      slides={[
        {
          title: "How Isabella and Zobia's Love for Music Changed Lives in Gaza",
          ctaLabel: "Read the story",
          ctaHref: "/stories/isabella-and-zobia-music-gaza",
          imageSrc: "https://i.vimeocdn.com/video/1998508960-e287b921ab19e39fddebdc288e869b3b6dc4bf34f76346ffae1a7ad8db086b3e-d_1280x720?region=us",
        },
        {
          title: "How An Nhi Sequestered Carbon by Planting Trees",
          ctaLabel: "Read the story",
          ctaHref: "/stories/an-nhi-carbon-trees",
          imageSrc: "https://i.vimeocdn.com/video/1998318368-6efeb691943e0074562f7674d93fdefea13719b5bbe909efbad5f2b9596dadef-d_1280x720?region=us",
        },
        {
          title: "How Damira and Aamna Launched Hoops4Hope in Qatar to Send Crucial Aid to Gazans",
          ctaLabel: "Read the story",
          ctaHref: "/stories/damira-aamna-hoops4hope",
          imageSrc: "/images/stories/damira-aamna-hoops4hope/hoops4hope.jpg",
        },
        {
          title: "How Panshul, Jad, and Yueqi Founded a Platform for Educational Accessibility",
          ctaLabel: "Read the story",
          ctaHref: "/stories/panshul-jad-yueqi-education",
          imageSrc: "/images/stories/panshul-jad-yueqi-education/accessifyed.png",
        },
      ]}
    />

    <Faq
      client:load
      title="Frequently Asked Questions"
      items={[
        {
          question: "What are cohorts?",
          answer: "Through our 3-month remote program, you work in a team of peers, guided by a coach, to effect measurable change through one of our 9 partner nonprofits or original initiatives.",
        },
        {
          question: "Who can join?",
          answer: "High school students aged 14-18, from anywhere in the world.",
        },
        {
          question: "Is there a cost?",
          answer: "Members pay an annual fee of $150. We provide full and partial scholarships to anyone in need. After we receive funding, we hope to lower or remove this fee.",
        },
        {
          question: "What's the time commitment?",
          answer: "Cohorts meet remotely for about one hour each week for 3 months. You'll also spend time working on your project between meetings. Total commitment is 3-5 hours per week, flexible to your schedule.",
        },
      ]}
    />

    <section class="bg-purple-dark-500 w-full px-12 py-24 flex flex-col gap-7 items-center text-center">
      <h2 class="font-semibold text-[40px] text-white max-w-[820px] leading-[1.2]">
        Ready to make an impact?
      </h2>
      <p class="text-white/80 text-lg max-w-[620px]">Join hundreds of change makers from around the world who are creating meaningful change through Ámaxa programs.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="https://airtable.com/appPR9mkslbn3U8YZ/shrHHUtRzK4DqKt3F"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-coral-dark-500 hover:bg-coral-dark-600 text-white text-base font-semibold px-6 py-3 rounded-full transition-colors"
        >
          Apply Now ↗
        </a>
        <a
          href="https://collect.crowded.me/collection/8d1ba838-a38e-4803-b155-d102b7b131e4"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border-[1.5px] border-white hover:bg-white hover:text-purple-dark-500 text-white text-base font-semibold px-6 py-3 rounded-full transition-colors"
        >
          Support Us
        </a>
      </div>
    </section>

    <NewsletterCta client:load />

    <ContactForm />

  </main>
</AppLayout>

---
import AppLayout from "@/layouts/app-layout.astro";
import IntroMedia from "@/components/sections/IntroMedia.astro";
import StatementBar from "@/components/sections/StatementBar.astro";
import HowItWorks from "@/components/sections/HowItWorks.astro";
import PhotoBanner from "@/components/sections/PhotoBanner.astro";
import { FeatureSlider3 } from "@/components/sections/FeatureSlider3";
import { NewsletterCta } from "@/components/sections/NewsletterCta";
import ContactForm from "@/components/sections/ContactForm.astro";
---

<AppLayout
  seo={{
    title: "Ámaxa Research",
    description: "Apply to ámaxa Research — for undergraduates and postgraduates. Produce actionable research that informs decision-making and implementation across our partner projects and initiatives.",
    image: "https://b47pkz22xs.ufs.sh/f/OxFTTzjZGToOTXSksZrPvV4ygRa57DXtJwU9SfhC1qxONmlA",
    type: "website",
    canonicalURL: "https://www.amaxaimpact.org/programs/research",
    keywords: ["amaxa", "research", "undergraduate", "PhD", "social change"],
    noIndex: false,
  }}
>
  <main>

    <IntroMedia
      heading="Research — for undergrads"
      subhead="Directly support ámaxa partner projects and initiatives by producing actionable research that informs decision-making and implementation."
      imageSrc="/images/programs/research.png"
      imageAlt="Ámaxa Research"
    />

    <StatementBar
      eyebrow="ABOUT"
      statement="Ámaxa Research seeks to give undergraduates the opportunity to gain meaningful research experience that pushes forward the mission of our partnerships & initiatives."
    />

    <HowItWorks
      title="How Ámaxa Research Works"
      steps={[
        { number: "STEP 01", heading: "Apply to the next Research cohort.", description: "Click on the application link to view the next cohort deadline." },
        { number: "STEP 02", heading: "Attend an interview", description: "Tell us about your interests, availability, and which projects excite you most." },
        { number: "STEP 03", heading: "Get matched to a research project", description: "Depending on needs of our partners and initiatives." },
        { number: "STEP 04", heading: "Meet weekly for 3 - 6 months", description: "One-hour weekly meetings guiding you through the research process." },
      ]}
    />

    <PhotoBanner
      eyebrow="FEATURED RESEARCH"
      heading="Stories of Sudan: University of Colorado Students Bring Awareness to Sudanese Culture"
      body="In our inaugural research cohort, three undergraduate students at the University of Colorado deliver research on Sudanese culture, bringing awareness to Sudanese people beyond the ongoing war."
      imageSrc="/images/programs/research/pyramids.avif"
      imageAlt="Pyramids of Sudan"
      buttonLabel="Learn More"
      buttonHref="/programs/research/sudan"
    />

    <FeatureSlider3
      client:load
      heading="Ongoing Research Projects"
      items={[
        { id: "1", title: "Stories of Sudan", subtitle: "Contributing accessible, well-sourced information about Sudan", href: "/programs/research/sudan", imageSrc: "/images/programs/research/sudan.jpg" },
        { id: "2", title: "Karina's Library Research", subtitle: "Research on the impact of literature on women and girls in the US & beyond", href: "/programs/research/literature-for-girls", imageSrc: "/images/programs/research/karinas-library.avif" },
        { id: "3", title: "Liberian Political History", subtitle: "Intensive research support to Educate Children founder, Sekou Jabateh", href: "/programs/research/liberia", imageSrc: "/images/programs/research/liberia.jpg" },
      ]}
    />

    <section class="bg-purple-dark-500 w-full px-6 md:px-12 py-24 flex flex-col gap-7 items-center text-center">
      <h2 class="font-semibold text-2xl md:text-3xl lg:text-[40px] text-white max-w-[820px] leading-[1.2]">
        Ready to make an impact?
      </h2>
      <p class="text-white/80 text-lg max-w-[620px]">Join hundreds of change makers from around the world who are creating meaningful change through Ámaxa programs.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="https://airtable.com/appPR9mkslbn3U8YZ/shrHHUtRzK4DqKt3F"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-coral-dark-500 hover:bg-coral-dark-600 text-white text-base font-semibold px-6 py-3 rounded-full transition-colors"
        >
          Apply Now ↗
        </a>
        <a
          href="https://collect.crowded.me/collection/8d1ba838-a38e-4803-b155-d102b7b131e4"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border-[1.5px] border-white hover:bg-white hover:text-purple-dark-500 text-white text-base font-semibold px-6 py-3 rounded-full transition-colors"
        >
          Support Us
        </a>
      </div>
    </section>

    <ContactForm />

    <NewsletterCta client:load />

  </main>
</AppLayout>

---
import AppLayout from "@/layouts/app-layout.astro";
import IntroMedia from "@/components/sections/IntroMedia.astro";
import StatementBar from "@/components/sections/StatementBar.astro";
import HowItWorks from "@/components/sections/HowItWorks.astro";
import TeamGrid from "@/components/sections/TeamGrid.astro";
import ImpactStats from "@/components/sections/ImpactStats.astro";
import SplitMedia from "@/components/sections/SplitMedia.astro";
import ContactForm from "@/components/sections/ContactForm.astro";

const barriers = [
  {
    heading: "I don't know how to start.",
    quote: "“There's so many problems in the world — how do I know who to volunteer with? It's too overwhelming.”",
  },
  {
    heading: "I'm not making a real impact.",
    quote: "“The last time I volunteered, I felt like I didn't actually make an impact.”",
  },
  {
    heading: "I'm in high school.",
    quote: "“Nonprofits ghost me — they don't take me seriously because of my age.”",
  },
  {
    heading: "I feel alone and don't have anyone to guide me.",
    quote: "“I would love to do something, but who is going to help me?”",
  },
  {
    heading: "Nothing near me feels meaningful.",
    quote: "“There are no groups I'm truly passionate about in my area.”",
  },
  {
    heading: "Nothing fits my schedule.",
    quote: "“The only nonprofit I like has meetings only during the workday.”",
  },
];
---

<AppLayout
  seo={{
    title: "About Ámaxa — Our Mission",
    description: "Ámaxa equips individuals around the world with the team, tools, coaching, and network to make a real impact.",
    image: "https://b47pkz22xs.ufs.sh/f/OxFTTzjZGToOexh9L5yvrS3NH5LD0fGBOXwFydpiVbYzJMa1",
    type: "website",
    canonicalURL: "https://www.amaxaimpact.org/about-us",
    keywords: ["amaxa", "about", "mission", "impact"],
    noIndex: false,
  }}
>
  <main>

    <IntroMedia
      heading="Ámaxa's Mission"
      subhead="Equipping individuals around the world with the team, tools, coaching, and network to make a real impact"
      imageSrc="/images/about-us/intro-media/hero.png"
      imageAlt="Ámaxa changemakers"
    />

    <StatementBar
      eyebrow="WHAT WE DO"
      statement="We connect people to grassroots organizations and initiatives doing community-based work in human rights, education, equity, and more — and help them contribute meaningfully through fully remote programs."
    />

    <!-- Barriers -->
    <section class="bg-neutral-1-500 w-full px-6 md:px-12 py-24 flex flex-col gap-12">
      <h2 class="font-semibold text-2xl md:text-3xl lg:text-[40px] text-purple-dark-500 leading-tight max-w-[720px]">
        I wish I could help — but what can I do?
      </h2>
      <div class="flex flex-col">
        {barriers.map((b) => (
          <div class="border-t border-border py-8 flex flex-col gap-3">
            <p class="font-semibold text-[22px] text-purple-dark-500">{b.heading}</p>
            <p class="font-normal text-lg text-muted-foreground italic max-w-[900px] leading-relaxed">{b.quote}</p>
          </div>
        ))}
      </div>
    </section>

    <ImpactStats
      title="By the numbers"
      stats={[
        { number: "250+", label: "applications from changemakers" },
        { number: "52", label: "Countries of applicants" },
        { number: "120+", label: "students completed the program" },
        { number: "8", label: "nonprofit partners & initiatives" },
      ]}
      ctaLabel="See our projects"
      ctaHref="/project"
    />

    <HowItWorks
      title="How it works"
      steps={[
        { number: "STEP 01", heading: "Global teams", description: "Students are paired with motivated peers from around the world." },
        { number: "STEP 02", heading: "A trained coach", description: "Every team is guided by a trained undergraduate coach." },
        { number: "STEP 03", heading: "Skills + a platform", description: "Project management and skills training, plus a custom online platform to run the work." },
        { number: "STEP 04", heading: "Real impact", description: "Teams bring a high-impact project to life with one of our nine nonprofit partners." },
      ]}
    />

    <!-- Our Programs (mirrors the Programs page) -->
    <section class="bg-neutral-1-500 w-full px-6 md:px-12 pt-24 pb-2">
      <h2 class="font-semibold text-2xl md:text-3xl lg:text-[40px] text-purple-dark-500">Our Programs</h2>
    </section>

    <SplitMedia
      heading="Cohorts — for high school students"
      subhead="Our flagship program: free and fully remote, pairing high schoolers with global peers and a trained coach to deliver a real project with one of our nonprofit partners."
      ctaLabel="Learn More"
      ctaHref="/programs/cohorts"
      mediaSrc="/images/programs/cohorts.png"
      mediaAlt="Ámaxa Cohorts"
      panelSide="right"
    />

    <SplitMedia
      heading="Cross-Border Access Program"
      subhead="A student-led international virtual exchange program, bringing extracurricular learning to students without access around the globe."
      ctaLabel="Learn More"
      ctaHref="/project/cross-border-access"
      mediaSrc="/images/programs/cross-border-access.png"
      mediaAlt="Cross-Border Access Program"
      panelSide="right"
    />

    <SplitMedia
      heading="Research — for university students"
      subhead="Undergraduate and postgraduate students take on applied research projects alongside our partners."
      ctaLabel="Learn More"
      ctaHref="/programs/research"
      mediaSrc="/images/programs/research.png"
      mediaAlt="Ámaxa Research"
      panelSide="right"
    />

    <SplitMedia
      heading="Partnerships — for professionals"
      subhead="Professionals lend their skills and networks to grassroots organizations through structured, fully remote engagements."
      ctaLabel="Learn More"
      ctaHref="/programs/partnerships"
      mediaSrc="/images/programs/partnerships.png"
      mediaAlt="Ámaxa Partnerships"
      panelSide="right"
    />

    <TeamGrid
      heading="Leadership Team"
      subhead="Meet the people behind Ámaxa's work."
      members={[
        { name: "Lauren McMillen", role: "Founder & Director", tone: "coral" },
        { name: "Alexi Jones", role: "Head of Programs", tone: "lavender", imageSrc: "/images/teams/lgbtq/alexi-jones.png" },
        { name: "Sahr Felle", role: "Educate Children Partnership Lead", tone: "coral", imageSrc: "/images/teams/educhildren/sahr-felle.jpeg" },
        { joinCard: true },
      ]}
    />

    <ContactForm />

  </main>
</AppLayout>

---
import AppLayout from "@/layouts/app-layout.astro";
import SplitMedia from "@/components/sections/SplitMedia.astro";
import TeamGrid from "@/components/sections/TeamGrid.astro";
import ProjectTypes from "@/components/sections/ProjectTypes.astro";
import { NewsletterCta } from "@/components/sections/NewsletterCta";
import ContactForm from "@/components/sections/ContactForm.astro";
---

<AppLayout
  seo={{
    title: "Karina's Library — Ámaxa Projects",
    description:
      "Ámaxa students work with Karina's Library to expand access to books and literacy programs for children in Guatemala.",
    image: "/images/projects/karinas-library.png",
    type: "website",
    canonicalURL: "https://www.amaxaimpact.org/project/karinas-library",
    keywords: ["amaxa", "Karina's Library", "Guatemala", "literacy", "books"],
    noIndex: false,
  }}
>
  <main>

    <section class="bg-neutral-1-500 w-full px-6 md:px-12 pt-[120px] pb-12">
      <h1 class="font-semibold text-3xl sm:text-4xl md:text-5xl lg:text-[56px] text-purple-dark-500 leading-[1.1] max-w-[900px]">
        Book bans and censorship threaten the lives of women and girls in the US and beyond.
      </h1>
    </section>

    <SplitMedia
      mediaSrc="/images/projects/karinas-library.png"
      heading="Our Initiative: Karina's Library"
      subhead="Karina's Library is centered on representation and education, and is one of ámaxa's newest projects. It is in honor of our late Chief Partnerships Officer, Karina Miszori, who fought for a world in which every child can see themselves in the stories they read."
      showCta={false}
      panelSide="left"
      large={true}
    />

    <TeamGrid
      heading="The Karina's Library Team"
      members={[
        { joinCard: true },
      ]}
    />

    <ProjectTypes
      heading="What kind of projects will I work on?"
      body="Ámaxa Cohorts projects are each 100% unique — driven by ámaxa members' passions, interests, skills, networks, and location."
      note="With Karina's Library, teams can take on projects focusing on <strong>book drives</strong>, <strong>fundraising</strong>, <strong>research</strong>, and <strong>outreach</strong>."
      chips={["Community Book Drives", "Fundraising Events", "Research on Literature and Education Strategies", "Community Outreach"]}
      ctaLabel="Learn about Cohorts projects"
      ctaHref="/programs/cohorts"
    />

    <NewsletterCta client:load />

    <section class="bg-purple-dark-500 w-full px-6 md:px-12 py-24 flex flex-col gap-7 items-center text-center">
      <h2 class="font-semibold text-2xl md:text-3xl lg:text-[40px] text-white max-w-[820px] leading-[1.2]">
        Ready to make an impact?
      </h2>
      <p class="text-white/80 text-lg max-w-[620px]">Join hundreds of change makers from around the world who are creating meaningful change through Ámaxa programs.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="https://airtable.com/appPR9mkslbn3U8YZ/shrHHUtRzK4DqKt3F"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-coral-dark-500 hover:bg-coral-dark-600 text-white text-base font-semibold px-6 py-3 rounded-full transition-colors"
        >
          Apply Now ↗
        </a>
        <a
          href="https://collect.crowded.me/collection/8d1ba838-a38e-4803-b155-d102b7b131e4"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border-[1.5px] border-white hover:bg-white hover:text-purple-dark-500 text-white text-base font-semibold px-6 py-3 rounded-full transition-colors"
        >
          Support Us
        </a>
      </div>
    </section>

    <ContactForm />

  </main>
</AppLayout>

---
import AppLayout from "@/layouts/app-layout.astro";
import SplitMedia from "@/components/sections/SplitMedia.astro";
import TeamGrid from "@/components/sections/TeamGrid.astro";
import ProjectTypes from "@/components/sections/ProjectTypes.astro";
import { ProjectFeatureSlider } from "@/components/sections/ProjectFeatureSlider";
import { NewsletterCta } from "@/components/sections/NewsletterCta";
import ContactForm from "@/components/sections/ContactForm.astro";
---

<AppLayout
  seo={{
    title: "Global Forest Generation — Ámaxa Projects",
    description:
      "Ámaxa students work with Global Forest Generation to plant trees, restore ecosystems, and build climate resilience in communities around the world.",
    image: "/images/projects/global-forest.png",
    type: "website",
    canonicalURL: "https://www.amaxaimpact.org/project/global-forest",
    keywords: ["amaxa", "global forest", "climate", "trees", "environment"],
    noIndex: false,
  }}
>
  <main>

    <section class="bg-neutral-1-500 w-full px-6 md:px-12 pt-[120px] pb-12">
      <h1 class="font-semibold text-3xl sm:text-4xl md:text-5xl lg:text-[56px] text-purple-dark-500 leading-[1.1] max-w-[900px]">
        Big corporations and governments are not doing enough to save our planet from climate change.
      </h1>
    </section>

    <SplitMedia
      mediaSrc="/images/projects/global-forest.png"
      heading="Our Initiative: Ámaxa Global Forest"
      subhead="As part of your ámaxa team, you raise funds to purchase seedlings or young trees, then plant them in local communities around the world. Once trees are planted, ámaxa teams measure the carbon sequestration impact of their work."
      showCta={false}
      panelSide="left"
      large={true}
    />

    <TeamGrid
      heading="The Global Forest Team"
      members={[
        { joinCard: true },
      ]}
    />

    <ProjectTypes
      heading="What kind of projects will I work on?"
      body="Ámaxa Cohorts projects are each 100% unique — driven by ámaxa members' passions, interests, skills, networks, and location."
      note='With the Global Forest initiative, teams take on projects that combine <strong>field research</strong>, <strong>fundraising</strong>, <strong>data measurement</strong>, and <strong>hands-on tree planting</strong>.'
      chips={["Environmental Research", "Fundraising Events", "Data & Measurement", "Planting trees in your community"]}
      ctaLabel="Learn about Cohorts projects"
      ctaHref="/programs/cohorts"
    />

    <ProjectFeatureSlider
      client:load
      heading="Explore Past Projects"
      slides={[
        {
          title: "How An Nhi Sequestered Carbon by Planting Trees",
          ctaLabel: "Read the story",
          ctaHref: "/stories/an-nhi-carbon-trees",
          imageSrc: "https://i.vimeocdn.com/video/1998318368-6efeb691943e0074562f7674d93fdefea13719b5bbe909efbad5f2b9596dadef-d_1280x720?region=us",
        },
      ]}
    />

    <NewsletterCta client:load />

    <section class="bg-purple-dark-500 w-full px-6 md:px-12 py-24 flex flex-col gap-7 items-center text-center">
      <h2 class="font-semibold text-2xl md:text-3xl lg:text-[40px] text-white max-w-[820px] leading-[1.2]">
        Ready to make an impact?
      </h2>
      <p class="text-white/80 text-lg max-w-[620px]">Join hundreds of change makers from around the world who are creating meaningful change through Ámaxa programs.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="https://airtable.com/appPR9mkslbn3U8YZ/shrHHUtRzK4DqKt3F"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-coral-dark-500 hover:bg-coral-dark-600 text-white text-base font-semibold px-6 py-3 rounded-full transition-colors"
        >
          Apply Now ↗
        </a>
        <a
          href="https://collect.crowded.me/collection/8d1ba838-a38e-4803-b155-d102b7b131e4"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border-[1.5px] border-white hover:bg-white hover:text-purple-dark-500 text-white text-base font-semibold px-6 py-3 rounded-full transition-colors"
        >
          Support Us
        </a>
      </div>
    </section>

    <ContactForm />

  </main>
</AppLayout>

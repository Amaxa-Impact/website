---
import AppLayout from "@/layouts/app-layout.astro";
import SplitMedia from "@/components/sections/SplitMedia.astro";
import TeamGrid from "@/components/sections/TeamGrid.astro";
import ProjectTypes from "@/components/sections/ProjectTypes.astro";
import { NewsletterCta } from "@/components/sections/NewsletterCta";
import ContactForm from "@/components/sections/ContactForm.astro";
---

<AppLayout
  seo={{
    title: "LGBTQ+ Artists Program — Ámaxa Initiatives",
    description:
      "Ámaxa's LGBTQ+ Artists Program creates visibility and amplifies LGBTQ+ storytellers through student-led PR, marketing, and advocacy campaigns.",
    image: "/images/projects/lgbtq.png",
    type: "website",
    canonicalURL: "https://www.amaxaimpact.org/project/lgbtq",
    keywords: ["amaxa", "LGBTQ+", "artists", "representation", "youth", "global initiative"],
    noIndex: false,
  }}
>
  <main>

    <section class="bg-neutral-1-500 w-full px-12 pt-[120px] pb-12">
      <h1 class="font-semibold text-[56px] text-purple-dark-500 leading-[1.1] max-w-[900px]">
        LGBTQ+ artists and queer stories are underrepresented and underfunded.
      </h1>
    </section>

    <SplitMedia
      mediaSrc="/images/projects/lgbtq.png"
      heading="Our Initiative: LGBTQ+ Artists Program"
      subhead="This program is ámaxa's way of helping LGBTQ+ artists and storytellers get the attention they deserve, while giving our students tangible experience in their fields of interest. Through an application opened before each cycle, artists can apply to be our next feature artist and benefit from our team of young marketing and PR professionals."
      showCta={false}
      panelSide="left"
      large={true}
    />

    <SplitMedia
      mediaSrc="/images/projects/lgbtq/platforming-refugee-stories.webp"
      heading="Platforming refugee stories"
      subhead={`Our 2025 highlight: "Won't Be Displaced" tells the story, through film, of refugees forced to flee their homeland because being gay is illegal or unprotected where they live. "We aim to show how creativity and the arts can drive policy change, in partnership with leading NGOs and advocates." — Piera van de Wiel, Writer, Director & Producer.`}
      showCta={false}
      panelSide="right"
    />

    <TeamGrid
      heading="The LGBTQ+ Artists Team"
      members={[
        { name: "Alexi Jones", role: "LGBTQ+ Artists Partnership Lead", tone: "coral", imageSrc: "/images/teams/lgbtq/alexi-jones.png" },
        { name: "Piera Van de Wiel", role: "Artist & Documentary Director", tone: "lavender", imageSrc: "/images/teams/lgbtq/piera-van-de-wiel.jpeg" },
        { joinCard: true },
      ]}
    />

    <ProjectTypes
      heading="What kind of projects will I work on?"
      body="Ámaxa Cohorts projects are each 100% unique — driven by ámaxa members' passions, interests, skills, networks, and location."
      note='The LGBTQ+ Artists Program centers on <strong>PR</strong>, <strong>marketing</strong>, and <strong>storytelling</strong>.'
      chips={["PR & marketing", "Content creation", "Storytelling", "Advocacy"]}
      ctaLabel="Learn about Cohorts projects"
      ctaHref="/programs/cohorts"
    />

    <NewsletterCta client:load />

    <section class="bg-purple-dark-500 w-full px-12 py-24 flex flex-col gap-7 items-center text-center">
      <h2 class="font-semibold text-[40px] text-white max-w-[820px] leading-[1.2]">
        Ready to make an impact?
      </h2>
      <p class="text-white/80 text-lg max-w-[620px]">Join hundreds of change makers from around the world who are creating meaningful change through Ámaxa programs.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="https://airtable.com/appPR9mkslbn3U8YZ/shrHHUtRzK4DqKt3F"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-coral-dark-500 hover:bg-coral-dark-600 text-white text-base font-semibold px-6 py-3 rounded-full transition-colors"
        >
          Apply Now ↗
        </a>
        <a
          href="https://collect.crowded.me/collection/8d1ba838-a38e-4803-b155-d102b7b131e4"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border-[1.5px] border-white hover:bg-white hover:text-purple-dark-500 text-white text-base font-semibold px-6 py-3 rounded-full transition-colors"
        >
          Support Us
        </a>
      </div>
    </section>

    <ContactForm />

  </main>
</AppLayout>

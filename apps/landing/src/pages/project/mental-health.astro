---
import AppLayout from "@/layouts/app-layout.astro";
import SplitMedia from "@/components/sections/SplitMedia.astro";
import TeamGrid from "@/components/sections/TeamGrid.astro";
import ProjectTypes from "@/components/sections/ProjectTypes.astro";
import { NewsletterCta } from "@/components/sections/NewsletterCta";
import ContactForm from "@/components/sections/ContactForm.astro";
---

<AppLayout
  seo={{
    title: "Mental Health First Aid — Ámaxa Initiatives",
    description:
      "Ámaxa's Mental Health First Aid initiative equips young people with the knowledge and tools to support mental health in their communities.",
    image: "/images/projects/mental-health.png",
    type: "website",
    canonicalURL: "https://www.amaxaimpact.org/project/mental-health",
    keywords: ["amaxa", "mental health", "first aid", "youth", "wellbeing"],
    noIndex: false,
  }}
>
  <main>

    <section class="bg-neutral-1-500 w-full px-12 pt-[120px] pb-12">
      <h1 class="font-semibold text-[56px] text-purple-dark-500 leading-[1.1] max-w-[900px]">
        Teens are lost every day to suicide. Friends and family need more knowledge to recognize symptoms & take action.
      </h1>
    </section>

    <SplitMedia
      mediaSrc="/images/projects/mental-health.png"
      heading="Our Initiative: Mental Health First Aid"
      subhead="Ámaxa teams compile a comprehensive database of mental health resources at the country, state, and local level, so that wherever you are, you can find help, resources, and community."
      ctaLabel="Learn More"
      ctaHref="/project/mental-health"
      panelSide="left"
      large={true}
    />

    <TeamGrid
      heading="The Mental Health First Aid Team"
      members={[
        { joinCard: true },
      ]}
    />

    <ProjectTypes
      heading="What kind of projects will I work on?"
      body="Ámaxa Cohorts projects are each 100% unique — driven by ámaxa members' passions, interests, skills, networks, and location."
      note='Mental Health First Aid projects include a diverse array of projects, including <strong>mental health research</strong>, <strong>advocacy campaigns</strong>, <strong>creating educational resources</strong>, <strong>partnership outreach</strong>, <strong>public speaking</strong>, <strong>event planning</strong>, and <strong>peer education</strong>.'
      chips={["Research & Writing", "Community Outreach & Partnership Building", "Public Speaking & Event Organization", "Peer Education in Schools"]}
      ctaLabel="Learn about Cohorts projects"
      ctaHref="/pathways/cohorts"
    />

    <NewsletterCta client:load />

    <section class="bg-purple-dark-500 w-full px-12 py-24 flex flex-col gap-7 items-center text-center">
      <h2 class="font-semibold text-[40px] text-white max-w-[820px] leading-[1.2]">
        Ready to make an impact?
      </h2>
      <p class="text-white/80 text-lg max-w-[560px]">Join hundreds of students from around the world who are creating meaningful change through Ámaxa.</p>
      <div class="flex gap-4">
        <a
          href="https://airtable.com/appPR9mkslbn3U8YZ/shrHHUtRzK4DqKt3F"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-coral-dark-500 hover:bg-coral-dark-600 text-white text-base font-semibold px-6 py-3 rounded-full transition-colors"
        >
          Apply Now ↗
        </a>
        <a
          href="https://airtable.com/appPR9mkslbn3U8YZ/shrHHUtRzK4DqKt3F"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border-[1.5px] border-white hover:bg-white hover:text-purple-dark-500 text-white text-base font-semibold px-6 py-3 rounded-full transition-colors"
        >
          Support Us
        </a>
      </div>
    </section>

    <ContactForm />

  </main>
</AppLayout>

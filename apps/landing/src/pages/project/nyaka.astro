---
import AppLayout from "@/layouts/app-layout.astro";
import SplitMedia from "@/components/sections/SplitMedia.astro";
import TeamGrid from "@/components/sections/TeamGrid.astro";
import ProjectTypes from "@/components/sections/ProjectTypes.astro";
import { NewsletterCta } from "@/components/sections/NewsletterCta";
import ContactForm from "@/components/sections/ContactForm.astro";
---

<AppLayout
  seo={{
    title: "Nyaka AIDS Orphans Project — Ámaxa",
    description:
      "Ámaxa students partner with the Nyaka AIDS Orphans Project in Uganda to support orphaned children with education, nutrition, and community care.",
    image: "/images/projects/nyaka.png",
    type: "website",
    canonicalURL: "https://www.amaxaimpact.org/project/nyaka",
    keywords: ["amaxa", "Nyaka", "Uganda", "AIDS orphans", "education"],
    noIndex: false,
  }}
>
  <main>

    <section class="bg-neutral-1-500 w-full px-12 pt-[120px] pb-12">
      <h1 class="font-semibold text-[56px] text-purple-dark-500 leading-[1.1] max-w-[900px]">
        Women and the children they support in southwestern Uganda cannot work or do homework after the sun sets.
      </h1>
    </section>

    <SplitMedia
      mediaSrc="/images/projects/nyaka.png"
      heading="Our Partner: Nyaka Global"
      subhead="Nyaka supports AIDS orphans and vulnerable children in Uganda with schooling, meals, medical care, and community development programs."
      ctaLabel="Visit Their Website"
      ctaHref="https://nyakaglobal.org/"
      panelSide="left"
      large={true}
    />

    <TeamGrid
      heading="The Nyaka Team"
      members={[
        { joinCard: true },
      ]}
    />

    <ProjectTypes
      heading="What kind of projects will I work on?"
      body="Ámaxa Cohorts projects are each 100% unique — driven by ámaxa members' passions, interests, skills, networks, and location."
      note='With Nyaka, teams most often take on <strong>fundraising-based</strong> projects.'
      chips={["Fundraising", "Fundraising Event", "Social Media Campaigns", "Community Outreach"]}
      ctaLabel="Learn about Cohorts projects"
      ctaHref="/programs/cohorts"
    />

    <NewsletterCta client:load />

    <section class="bg-purple-dark-500 w-full px-12 py-24 flex flex-col gap-7 items-center text-center">
      <h2 class="font-semibold text-[40px] text-white max-w-[820px] leading-[1.2]">
        Ready to make an impact?
      </h2>
      <p class="text-white/80 text-lg max-w-[620px]">Join hundreds of change makers from around the world who are creating meaningful change through Ámaxa programs.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="https://airtable.com/appPR9mkslbn3U8YZ/shrHHUtRzK4DqKt3F"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-coral-dark-500 hover:bg-coral-dark-600 text-white text-base font-semibold px-6 py-3 rounded-full transition-colors"
        >
          Apply Now ↗
        </a>
        <a
          href="https://collect.crowded.me/collection/8d1ba838-a38e-4803-b155-d102b7b131e4"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border-[1.5px] border-white hover:bg-white hover:text-purple-dark-500 text-white text-base font-semibold px-6 py-3 rounded-full transition-colors"
        >
          Support Us
        </a>
      </div>
    </section>

    <ContactForm />

  </main>
</AppLayout>

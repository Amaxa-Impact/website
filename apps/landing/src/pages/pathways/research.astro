---
import AppLayout from "@/layouts/app-layout.astro";
import IntroMedia from "@/components/sections/IntroMedia.astro";
import StatementBar from "@/components/sections/StatementBar.astro";
import HowItWorks from "@/components/sections/HowItWorks.astro";
import PhotoBanner from "@/components/sections/PhotoBanner.astro";
import { FeatureSlider3 } from "@/components/sections/FeatureSlider3";
import { Faq } from "@/components/sections/Faq";
import { NewsletterCta } from "@/components/sections/NewsletterCta";
import ContactForm from "@/components/sections/ContactForm.astro";

const researchTasks = `Ámaxa Research is an intensive program with diverse tasks, depending on project needs.

Responsibilities can include:
Finding supporting materials for research (past studies, documents, laws, surveys, etc.) and helping to pull pertinent information/synthesize with other materials.
Managing databases/spreadsheets of research materials and helping to classify/organize them.
Assisting with editing and revising research as needed, both on basics (grammar + spelling) and based on peer review feedback.
Creating visual aids for research findings (graphs/charts/infographics, etc.).
Helping to distill research findings into blog posts, LinkedIn posts and other public-facing materials.`;
---

<AppLayout
  seo={{
    title: "Ámaxa Research",
    description: "Apply to ámaxa Research — for undergraduates and postgraduates. Produce actionable research that informs decision-making and implementation across our partner projects and initiatives.",
    image: "https://b47pkz22xs.ufs.sh/f/OxFTTzjZGToOTXSksZrPvV4ygRa57DXtJwU9SfhC1qxONmlA",
    type: "website",
    canonicalURL: "https://www.amaxaimpact.org/pathways/research",
    keywords: ["amaxa", "research", "undergraduate", "PhD", "social change"],
    noIndex: false,
  }}
>
  <main>

    <IntroMedia
      heading="Research — for undergrads"
      subhead="Directly support ámaxa partner projects and initiatives by producing actionable research that informs decision-making and implementation."
      imageSrc="/images/programs/research.png"
      imageAlt="Ámaxa Research"
    />

    <StatementBar
      eyebrow="ABOUT"
      statement="Ámaxa Research seeks to give undergraduates the opportunity to gain meaningful research experience that pushes forward the mission of our partnerships & initiatives."
    />

    <HowItWorks
      title="How Ámaxa Research Works"
      steps={[
        { number: "STEP 01", heading: "Apply to the next Research cohort.", description: "Click on the application link to view the next cohort deadline." },
        { number: "STEP 02", heading: "Attend an interview", description: "Tell us about your interests, availability, and which projects excite you most." },
        { number: "STEP 03", heading: "Get matched to a research project", description: "Depending on needs of our partners and initiatives." },
        { number: "STEP 04", heading: "Meet weekly for 3 - 6 months", description: "One-hour weekly meetings guiding you through the research process." },
      ]}
    />

    <PhotoBanner
      eyebrow="FEATURED RESEARCH"
      heading="Stories of Sudan: University of Colorado Students Bring Awareness to Sudanese Culture"
      body="In our inaugural research cohort, three undergraduate students at the University of Colorado deliver research on Sudanese culture, bringing awareness to Sudanese people beyond the ongoing war."
      buttonLabel="Explore the research"
      buttonHref="/sudan-syllabus"
    />

    <FeatureSlider3
      client:load
      heading="Ongoing Research Projects"
      items={[
        { id: "1", title: "Stories of Sudan", subtitle: "Contributing accessible, well-sourced information about Sudan", href: "#" },
        { id: "2", title: "Karina's Library Research", subtitle: "Research on the impact of literature on women and girls in the US & beyond", href: "#" },
        { id: "3", title: "Liberian Political History", subtitle: "Intensive research support to Educate Children founder, Sekou Jabateh", href: "#" },
      ]}
    />

    <Faq
      client:load
      title="Frequently Asked Questions"
      items={[
        { question: "What tasks will I be responsible for as a Research cohort student?", answer: researchTasks },
        { question: "Who can join?", answer: "" },
        { question: "Is there a cost?", answer: "" },
        { question: "What's the time commitment?", answer: "" },
      ]}
    />

    <section class="bg-purple-dark-500 w-full px-12 py-24 flex flex-col gap-7 items-center text-center">
      <h2 class="font-semibold text-[40px] text-white max-w-[820px] leading-[1.2]">
        Ready to make an impact?
      </h2>
      <p class="text-white/80 text-lg max-w-[620px]">Join hundreds of students from around the world who are creating meaningful change through Ámaxa.</p>
      <a href="https://airtable.com/appPR9mkslbn3U8YZ/shrHHUtRzK4DqKt3F" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-coral-dark-500 hover:bg-coral-dark-600 text-white text-base font-semibold px-6 py-3 rounded-full transition-colors">
        Apply Now ↗
      </a>
    </section>

    <ContactForm />

    <NewsletterCta client:load />

  </main>
</AppLayout>
